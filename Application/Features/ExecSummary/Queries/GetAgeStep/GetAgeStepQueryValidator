using FluentValidation;

namespace DataAnalysis.Application.Features.ExecSummary.Queries.GetAgeStep;

public class GetAgeStepQueryValidator : AbstractValidator<GetAgeStepQuery>
{
    public GetAgeStepQueryValidator()
    {
        RuleFor(x => x.ProductGroup).IsInEnum();
        RuleFor(x => x.StartDate).NotEmpty();
        RuleFor(x => x.EndDate).NotEmpty().GreaterThanOrEqualTo(x => x.StartDate);
    }
}